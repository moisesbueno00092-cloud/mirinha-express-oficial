
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Function to check if a user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of a document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description
     *   Manages the user's own profile document.
     *   Only the owner of the document can read or write to it.
     */
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description
     *   Manages shared data and user-specific data collections.
     *   Security is primarily enforced at the application level by querying
     *   for documents with the correct userId. This simplified rule prevents
     *   list query permission errors while the app's queries ensure data privacy.
     */
    match /order_items/{orderItemId} {
       allow read, write: if isSignedIn();
    }

    match /favorite_clients/{clientId} {
       allow read, write: if isSignedIn();
    }

    match /bomboniere_items/{itemId} {
        allow read, write: if isSignedIn();
    }

    match /daily_reports/{reportId} {
      allow read, write: if isSignedIn();
    }

    match /expenses/{expenseId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /payables/{payableId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /employees/{employeeId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Salary advances for a specific employee.
      match /advances/{advanceId} {
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }
  }
}
