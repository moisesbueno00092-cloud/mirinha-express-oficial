
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description
     *   Manages the user's own profile document.
     *   Only the owner of the document can read or write to it.
     * @path
     *   /users/{userId}
     */
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description
     *   Manages order items. Security is enforced by application-level queries
     *   that filter by userId. Rules allow any signed-in user to perform actions,
     *   but the app logic restricts data access to the owner.
     * @path
     *   /order_items/{orderItemId}
     */
    match /order_items/{orderItemId} {
       allow read, write: if isSignedIn();
    }
    
    /**
     * @description
     *   Manages favorite clients. Security is enforced by application-level queries.
     * @path
     *   /favorite_clients/{clientId}
     */
    match /favorite_clients/{clientId} {
       allow read, write: if isSignedIn();
    }

    /**
     * @description
     *   Manages the shared list of bomboniere items (products).
     *   Allows any authenticated user to read or write, as stock management
     *   is handled collaboratively.
     * @path
     *   /bomboniere_items/{itemId}
     */
    match /bomboniere_items/{itemId} {
        allow read, write: if isSignedIn();
    }
    
    /**
     * @description
     *   Manages saved daily reports.
     *   Any authenticated user can read/write reports.
     * @path
     *   /daily_reports/{reportId}
     */
    match /daily_reports/{reportId} {
      allow read, write: if isSignedIn();
    }
  }
}
