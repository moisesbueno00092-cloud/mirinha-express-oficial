
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user owns the document
    // For reads/updates/deletes on existing documents
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper function to check if the user is creating a document for themselves
    // For create operations
    function isCreatingForSelf() {
      return request.auth.uid == request.resource.data.userId;
    }

    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if isOwner(userId);
    }
    
    match /order_items/{orderItemId} {
      allow get, update, delete: if isOwner(resource.data.userId);
      allow list: if isSignedIn();
      allow create: if isCreatingForSelf();
    }

    match /favorite_clients/{clientId} {
      allow get, update, delete: if isOwner(resource.data.userId);
      allow list: if isSignedIn();
      allow create: if isCreatingForSelf();
    }

    // bomboniere_items is public/shared data
    match /bomboniere_items/{itemId} {
      allow read, write: if isSignedIn();
    }
    
    // daily_reports are system-wide
    match /daily_reports/{reportId} {
       allow read, write: if isSignedIn();
    }

    match /expenses/{expenseId} {
      allow get, update, delete: if isOwner(resource.data.userId);
      allow list: if isSignedIn();
      allow create: if isCreatingForSelf();
    }
    
    match /employees/{employeeId} {
      allow get, update, delete: if isOwner(resource.data.userId);
      allow list: if isSignedIn();
      allow create: if isCreatingForSelf();

      match /advances/{advanceId} {
        allow get, update, delete: if isOwner(resource.data.userId);
        allow list: if isSignedIn(); // Allow listing advances for a specific employee
        allow create: if isCreatingForSelf();
      }
    }
  }
}
