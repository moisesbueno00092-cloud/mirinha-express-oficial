
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description
     *   Manages the user's own profile document.
     *   Only the owner of the document can read or write to it.
     * @path
     *   /users/{userId}
     */
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description
     *   Manages order items, favorite clients, bomboniere items, daily reports,
     *   expenses, payables, and employees.
     *   Authenticated users can read and write to these collections.
     *   Security is enforced at the application level by querying for documents
     *   with the correct userId.
     */
    match /order_items/{orderItemId} {
       allow read, write: if isSignedIn();
    }

    match /favorite_clients/{clientId} {
       allow read, write: if isSignedIn();
    }

    match /bomboniere_items/{itemId} {
        allow read, write: if isSignedIn();
    }

    match /daily_reports/{reportId} {
      allow read, write: if isSignedIn();
    }

    match /expenses/{expenseId} {
      allow read, write: if isSignedIn();
    }

    match /payables/{payableId} {
      allow read, write: if isSignedIn();
    }

    match /employees/{employeeId} {
      allow read, write: if isSignedIn();
      
      // Salary advances for a specific employee.
      match /advances/{advanceId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
