
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users can only access their own profile
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Rules for collections where documents have a 'userId' field
    match /order_items/{orderItemId} {
      allow read, write: if request.auth != null && (isOwner(request.resource.data.userId) || isOwner(resource.data.userId));
      allow list: if request.auth != null && request.query.resource.data.userId == request.auth.uid;
    }

    match /favorite_clients/{clientId} {
       allow read, write: if request.auth != null && (isOwner(request.resource.data.userId) || isOwner(resource.data.userId));
       allow list: if request.auth != null && request.query.resource.data.userId == request.auth.uid;
    }
    
    match /expenses/{expenseId} {
       allow read, write: if request.auth != null && (isOwner(request.resource.data.userId) || isOwner(resource.data.userId));
       allow list: if request.auth != null && request.query.resource.data.userId == request.auth.uid;
    }
    
    match /payables/{payableId} {
       allow read, write: if request.auth != null && (isOwner(request.resource.data.userId) || isOwner(resource.data.userId));
       allow list: if request.auth != null && request.query.resource.data.userId == request.auth.uid;
    }

    // Rules for bomboniere items (shared) and daily reports (admin-only, assumed for now)
    match /bomboniere_items/{itemId} {
      allow read, write: if request.auth != null;
    }

    match /daily_reports/{reportId} {
      allow read, write: if request.auth != null;
    }
    
    // Employees and their advances
    match /employees/{employeeId} {
       allow read, write: if request.auth != null && (isOwner(request.resource.data.userId) || isOwner(resource.data.userId));
       allow list: if request.auth != null && request.query.resource.data.userId == request.auth.uid;

      match /advances/{advanceId} {
        allow read, write: if request.auth != null; // Allow if user has access to parent employee
      }
    }
    
    // Fallback for any other path - deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
