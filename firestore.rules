
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description
     *   Manages the user's own profile document.
     *   Only the owner of the document can read or write to it.
     * @path
     *   /users/{userId}
     */
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description
     *   Manages order items. Users can create their own items.
     *   They can read, update, or delete items they own.
     *   Listing is implicitly allowed if the client-side query is correctly filtered by userId.
     */
    match /order_items/{orderItemId} {
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
       allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    /**
     * @description
     *   Manages favorite clients. Same logic as order_items.
     * @path
     *   /favorite_clients/{clientId}
     */
    match /favorite_clients/{clientId} {
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
       allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /**
     * @description
     *   Manages the shared list of bomboniere items (products).
     *   Allows any authenticated user to read or write, as stock management
     *   is handled collaboratively.
     * @path
     *   /bomboniere_items/{itemId}
     */
    match /bomboniere_items/{itemId} {
        allow read, write: if isSignedIn();
    }
    
    /**
     * @description
     *   Manages saved daily reports.
     *   Any authenticated user can read/write reports.
     * @path
     *   /daily_reports/{reportId}
     */
    match /daily_reports/{reportId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description
     *  Manages expenses, payables, and employees.
     *  Users can create their own items.
     *  They can read, update, or delete items they own.
     *  Listing is allowed only when querying by the user's own ID.
     */
    function isQueryingOwnData() {
      return request.query.where.size == 1 &&
             request.query.where[0].fieldPath == 'userId' &&
             request.query.where[0].op == '==' &&
             request.query.where[0].value == request.auth.uid;
    }
    
    match /expenses/{expenseId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && isQueryingOwnData();
    }

    match /payables/{payableId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && isQueryingOwnData();
    }

    match /employees/{employeeId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && isQueryingOwnData();
      
      // Salary advances for a specific employee.
      // List is allowed if the parent employee can be read.
      match /advances/{advanceId} {
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }
  }
}
