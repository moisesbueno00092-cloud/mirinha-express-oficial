rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    match /order_items/{docId} {
      allow read, write: if true;
    }

    match /daily_reports/{docId} {
      allow read, write: if true;
    }

    // Rule for listing the entire collection
    match /client_accounts {
      allow list: if true;
    }

    // Rule for individual document operations
    match /client_accounts/{clientAccountId} {
      allow read, write, delete: if true;
    }

    match /bomboniere_items/{docId} {
      allow read, write: if true;
    }

    match /favorite_clients/{docId} {
      allow read, write: if true;
    }
  }
}
