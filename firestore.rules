
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // This rule allows any user to read or write to any document.
    // The application's security is enforced by client-side queries
    // that filter data by the authenticated user's ID (`where('userId', '==', user.uid)`).
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
