
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isReadingOwnData(userId) {
      return request.method == 'get' && isOwner(userId);
    }
    
    function isListingOwnData(userId) {
      // This rule is tricky. It ensures that a 'list' operation (like in a collection query)
      // is only allowed if the query includes a 'where' clause that filters by the user's own ID.
      // This prevents a user from listing all documents in a collection.
      return request.method == 'list' && request.query.where.get('userId', '') == userId;
    }

    /**
     * @description
     *   Manages the user's own profile document.
     *   Only the owner of the document can read or write to it.
     * @path
     *   /users/{userId}
     */
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description
     *   Manages order items. Users can create their own items.
     *   They can read items if it's a single document they own, or
     *   if they are listing documents filtered by their own userId.
     * @path
     *   /order_items/{orderItemId}
     */
    match /order_items/{orderItemId} {
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
       allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    /**
     * @description
     *   Manages favorite clients. Same logic as order_items.
     * @path
     *   /favorite_clients/{clientId}
     */
    match /favorite_clients/{clientId} {
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
       allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /**
     * @description
     *   Manages the shared list of bomboniere items (products).
     *   Allows any authenticated user to read or write, as stock management
     *   is handled collaboratively.
     * @path
     *   /bomboniere_items/{itemId}
     */
    match /bomboniere_items/{itemId} {
        allow read, write: if isSignedIn();
    }
    
    /**
     * @description
     *   Manages saved daily reports.
     *   Any authenticated user can read/write reports.
     * @path
     *   /daily_reports/{reportId}
     */
    match /daily_reports/{reportId} {
      allow read, write: if isSignedIn();
    }
  }
}
