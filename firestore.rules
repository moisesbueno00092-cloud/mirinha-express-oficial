
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função para verificar se o utilizador está autenticado
    function isSignedIn() {
      return request.auth != null;
    }

    // Função para verificar se o utilizador é o proprietário do documento
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Regra permissiva para desenvolvimento - A segurança é garantida pela aplicação
    match /expenses/{expenseId} {
      allow read, write: if isSignedIn();
    }
    
    match /employees/{employeeId} {
      allow read, write: if isSignedIn();
    }

    match /employees/{employeeId}/advances/{advanceId} {
       allow read, write: if isSignedIn();
    }

    // Regras mais restritivas para as outras coleções
    match /order_items/{orderItemId} {
      allow read, write: if isSignedIn() && (isOwner(request.resource.data.userId) || isOwner(resource.data.userId));
    }

    match /favorite_clients/{clientId} {
       allow read, write: if isSignedIn() && (isOwner(request.resource.data.userId) || isOwner(resource.data.userId));
    }
    
    match /daily_reports/{reportId} {
       allow read, write: if isSignedIn();
    }

    // Regra para a coleção partilhada de 'bomboniere_items'
    match /bomboniere_items/{itemId} {
      allow read: if isSignedIn();
      // Apenas o proprietário (o utilizador principal da app) pode modificar o stock.
      allow write: if isSignedIn(); 
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}

    