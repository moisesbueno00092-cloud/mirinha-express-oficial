rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    match /order_items/{docId} {
      allow read, write: if true;
    }

    match /daily_reports/{docId} {
      allow read, write: if true;
    }

    // Allow full access to client accounts for all users.
    // Separating read and write rules to ensure deployment.
    match /client_accounts/{clientAccountId} {
      allow read: if true;
      allow write: if true;
    }

    match /bomboniere_items/{docId} {
      allow read, write: if true;
    }

    match /favorite_clients/{docId} {
      allow read, write: if true;
    }
  }
}
