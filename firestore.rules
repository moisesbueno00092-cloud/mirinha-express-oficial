rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Regra específica e segura para a subcoleção de pedidos do usuário
    match /users/{userId}/order_items/{orderItemId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regras explícitas para as outras coleções, permitindo acesso a qualquer usuário autenticado
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /bomboniere_items/{itemId} {
      allow read, write: if request.auth != null;
    }
    match /daily_reports/{reportId} {
      allow read, write: if request.auth != null;
    }
    match /fornecedores/{fornecedorId} {
      allow read, write: if request.auth != null;
    }
    match /contas_a_pagar/{contaId} {
      allow read, write: if request.auth != null;
    }
    match /entradas_mercadorias/{entradaId} {
      allow read, write: if request.auth != null;
    }
    match /funcionarios/{funcionarioId}/{document=**} {
        allow read, write: if request.auth != null;
    }
  }
}
