
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }

    // Allow signed-in users to read and write any document.
    // Security is enforced at the application level by querying
    // for documents with the correct userId.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
